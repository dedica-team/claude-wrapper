{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdates": false,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "allow": [
      "WebSearch",
      "WebFetch",
      "Edit(/**)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(gh *)",
      "Bash(git *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}