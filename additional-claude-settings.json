{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdates": false,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push *)"
    ],
    "allow": [
      "WebSearch",
      "WebFetch",

      "Edit(/**)",

      "Bash(cd *)",
      "Bash(pwd *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",

      "Bash(which *)",
      "Bash(command *)",

      "Bash(source *)",
      "Bash(sort *)",
      "Bash(wc *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(printf *)",
      "Bash(tee *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(less *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(gh *)",
      "Bash(git *)",

      "Bash(sdk *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(jar *)",
      "Bash(mvn *)",
      "Bash(./mvnw *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",

      "Bash(go *)",
      "Bash(gofmt *)",

      "Bash(python *)",
      "Bash(python3 *)",

      "Bash(convert *)",
      "Bash(identify *)",
      "Bash(mogrify *)",
      "Bash(magick *)",

      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",

      "Bash(node *)",
      "Bash(npm *)",
      "Bash(nvm *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  }
}