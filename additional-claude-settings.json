{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdates": false,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "allow": [
      "WebSearch",
      "WebFetch",

      "Edit(/**)",

      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(gh *)",
      "Bash(git *)",

      "Bash(sdk *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(jar *)",
      "Bash(mvn *)",
      "Bash(mvnw *)",
      "Bash(gradle *)",
      "Bash(gradlew *)",

      "Bash(go *)",
      "Bash(gofmt *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  }
}