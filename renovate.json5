{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    // No commits like "chore(deps): [...]"
    ":semanticCommitsDisabled",
    // Use hashes as references to GitHub actions as tags could be changed after release.
    "helpers:pinGitHubActionDigests",
    // Use hashes as references to Docker Images as tags could be changed after release.
    "docker:pinDigests"
  ],

  // Do not limit the number of dependency update Pull Requests.
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,

  "labels": [
    "Dependencies"
  ],

  "packageRules": [
    {
      // Wait some time before updating to a newer Claude Code version.
      "matchPackageNames": ["@anthropic-ai/claude-code"],
      "minimumReleaseAge": "7 days"
    }
  ],

  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^bin/claudew$", "^Dockerfile$"],
      "matchStrings": [
        // Update the default Claude Code version in the script.
        "DEFAULT_CLAUDE_VERSION=(?<currentValue>\\S+)",
        // Update the default Claude Code version in the Dockerfile.
        "ARG CLAUDE_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "@anthropic-ai/claude-code",
      "datasourceTemplate": "npm"
    }
  ]
}
