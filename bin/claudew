#!/usr/bin/env bash

#
# A wrapper that runs Claude in a container to restrict its access.
#
# Simplest usage: Switch to your project directory and run `claudew`:
#
#     cd ~/my-project
#     claudew
#
# Per default, claudew will continue the latest conversation for that project.
# Override that behavior by passing "--new-session" as a parameter.
#

# Stop script on failure.
set -e -o pipefail

CLAUDE_VERSION=${CLAUDE_VERSION:-2.1.74}

DOCKER="docker"
# If on Windows and using mingw64/Git-Bash, we need to prefix the docker command with "winpty"
if command -v winpty &> /dev/null; then
    DOCKER="winpty $DOCKER"
fi

# Build the Docker image, if it does not exist yet.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_TAG=claudew:${CLAUDE_VERSION}
if ! $DOCKER image inspect "${IMAGE_TAG}" &> /dev/null; then
    echo "Docker image '${IMAGE_TAG}' not found. Building it now..."
    $DOCKER build --build-arg "CLAUDE_VERSION=${CLAUDE_VERSION}" --tag "${IMAGE_TAG}" "${SCRIPT_DIR}/.."
fi

# Create config files for Claudew on the host system.
CLAUDEW_CONFIG_DIRECTORY=~/.claudew
CLAUDEW_CONFIG_FILE=~/.claudew.json
mkdir -p ${CLAUDEW_CONFIG_DIRECTORY}
if [ ! -f ${CLAUDEW_CONFIG_FILE} ]; then
  # Initialize config file.
  echo "{}" > ${CLAUDEW_CONFIG_FILE}
fi

CLAUDE_HOME=/home/claude
PROJECT_NAME=$(basename "$(pwd)")
PROJECT_DIR=${CLAUDE_HOME}/project/${PROJECT_NAME}
ADDITIONAL_SETTINGS_PATH=${SCRIPT_DIR}/../additional-claude-settings.json

# Per default, the previous conversation in a project is continued (if one exists),
# unless the --new-session flag is passed.
# That flag is not among the default Claude parameters and will not be
# passed on.
PROJECT_SESSION_DIR="${CLAUDEW_CONFIG_DIRECTORY}/projects/-home-claude-project-${PROJECT_NAME}"
if compgen -G "${PROJECT_SESSION_DIR}/*.jsonl" > /dev/null 2>&1; then
    # Previous session exists.
    CONTINUE_FLAG="--continue"
else
    CONTINUE_FLAG=""
fi
PASSTHROUGH_ARGS=()
for arg in "$@"; do
    if [ "$arg" = "--new-session" ]; then
        CONTINUE_FLAG=""
    else
        if [ "$arg" = "--resume" ] || [ "$arg" = "--continue" ]; then
            # The user wants to resume a session (which might not be compatible with --continue)
            # or explicitly passed --continue.
            # In both cases, we do not want to inject another --continue flag.
            CONTINUE_FLAG=""
        fi
        PASSTHROUGH_ARGS+=("$arg")
    fi
done

DOCKER_ARGS=(
    --user "$(id -u):$(id -g)" --rm
    --interactive --tty
    --volume "$(pwd):${PROJECT_DIR}"
    --workdir "${PROJECT_DIR}"
    --volume "${CLAUDEW_CONFIG_DIRECTORY}:${CLAUDE_HOME}/.claude/"
    --volume "${CLAUDEW_CONFIG_FILE}:${CLAUDE_HOME}/.claude.json"
    --volume "${ADDITIONAL_SETTINGS_PATH}:${CLAUDE_HOME}/additional-claude-settings.json"
    --env "HOME=${CLAUDE_HOME}"
    --env "ADDITIONAL_CLAUDE_ARGUMENTS=--settings ${CLAUDE_HOME}/additional-claude-settings.json ${CONTINUE_FLAG} ${PASSTHROUGH_ARGS[*]}"
)

# If the project has a .env file, mount a file over it to prevent secrets from leaking into the container.
if [ -f "$(pwd)/.env" ]; then
    DOCKER_ARGS+=(--volume "${SCRIPT_DIR}/../not-allowed-to-read.txt:${PROJECT_DIR}/.env")
fi
# Also block .env files one level deeper.
for env_file in "$(pwd)"/*/.env; do
    if [ -f "${env_file}" ]; then
        subdirectory=$(basename "$(dirname "${env_file}")")
        DOCKER_ARGS+=(--volume "${SCRIPT_DIR}/../not-allowed-to-read.txt:${PROJECT_DIR}/${subdirectory}/.env")
    fi
done

exec $DOCKER run "${DOCKER_ARGS[@]}" "${IMAGE_TAG}"
